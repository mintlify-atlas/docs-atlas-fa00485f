{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Circuit Breaker Labs CLI",
  "theme": "aspen",
  "colors": {
    "primary": "#8B5CF6",
    "light": "#C4B5FD",
    "dark": "#6D28D9"
  },
  "navbar": {
